# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to GitHub.
# ─────────────────────────────────────────────────────────────────────────────

# NewsAPI (get a free key at https://newsapi.org)
NEWS_API_KEY=your_newsapi_key_here

# MLflow tracking URI (local default — change for remote server)
MLFLOW_TRACKING_URI=http://localhost:5000

# Feature Store path (local directory for Parquet files)
FEATURE_STORE_PATH=./feature_store

# Model name registered in MLflow Registry
MLFLOW_MODEL_NAME=news-credibility-scorer

# Airflow (only needed if running Airflow locally)
AIRFLOW_HOME=./airflow
